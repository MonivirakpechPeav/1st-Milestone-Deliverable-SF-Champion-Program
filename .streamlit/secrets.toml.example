[connections.snowflake]
# Use the account identifier from your Snowflake URL.
# For https://orgname-accountname.snowflakecomputing.com:
account = "orgname-accountname"
# For locator-style URLs, include region/cloud when present, for example:
# account = "ve82242.ap-southeast-1.aws"
user = "YOUR_USER"
password = "YOUR_PASSWORD"
role = "ACCOUNTADMIN"
warehouse = "COMPUTE_WH"

# database / schema are chosen at runtime in the sidebar
